apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: {{ .AppName }}-daemonset
spec:
  selector:
    matchLabels:
      app: {{ .AppName }}
  template:
    metadata:
      labels:
        app: {{ .AppName }}
    spec:
      containers:
      - name: {{ .AppName }}
        image: {{ .Image }}:{{ .Tag }}
